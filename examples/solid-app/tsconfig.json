{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "strict": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@capgo/capacitor-sheets": ["../../src/index.ts"],
      "@capgo/capacitor-sheets/solid": ["../../src/solid/index.ts"]
    }
  },
  "include": ["src"]
}
