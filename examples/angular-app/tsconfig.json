{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "baseUrl": ".",
    "paths": {
      "@capgo/capacitor-sheets": ["../../src/index.ts"],
      "@capgo/capacitor-sheets/angular": ["../../src/angular/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "strictTemplates": true
  }
}
