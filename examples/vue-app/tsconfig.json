{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@capgo/capacitor-sheets": ["../../src/index.ts"],
      "@capgo/capacitor-sheets/vue": ["../../src/vue/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue"]
}
